namespace SuOS.Uds.Msg.General;

// ---- 空消息类型定义 (Command ID 映射) ----
table UsrStopRequest { }
table UsrStopKill { }

// ---- Union 定义 ----
// 使用 union 将所有可能的空消息统一起来
union GeneralPayload_fromMain {
    UsrStopRequest,
    UsrStopKill,
}

// ---- 包装表 ----
table GeneralEnvelope_fromMain {
    payload: GeneralPayload_fromMain;
}

root_type GeneralEnvelope_fromMain;